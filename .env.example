# PracticePanther MCP — credentials
# Get these by running the auth helper once:
#     practicepanther-mcp-auth --client-id <id> --client-secret <secret>
# It opens a browser, completes the OAuth flow, and prints env vars to set.
#
# Once you have the tokens, set them in your shell (or Claude Desktop config).

# Required: a long-lived access token (refreshed automatically from refresh_token)
PRACTICEPANTHER_ACCESS_TOKEN=

# Required: refresh token (60-day TTL — used to mint new access tokens)
PRACTICEPANTHER_REFRESH_TOKEN=

# Required: your registered PracticePanther OAuth app credentials
PRACTICEPANTHER_CLIENT_ID=
PRACTICEPANTHER_CLIENT_SECRET=

# Optional overrides
# PRACTICEPANTHER_BASE_URL=https://app.practicepanther.com
